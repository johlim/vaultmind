import os
import glob
import json
import re
import requests

# --- CONFIG ---
VAULT_PATH = os.path.expanduser("~/Obsidian")   # ← change this
OLLAMA_MODEL = "llama3.2:3b"
MEMORY_FILE = os.path.join(os.path.dirname(__file__), "memoria_memory.json")
MAX_NOTE_CHARS = 800   # per note, to avoid context overflow
MAX_NOTES = 60         # cap total notes loaded

# --- COLORS ---
R      = "\033[0m"
DIM    = "\033[2m"
BOLD   = "\033[1m"
CYAN   = "\033[36m"
PURPLE = "\033[35m"
GREEN  = "\033[32m"
YELLOW = "\033[33m"
RED    = "\033[31m"

# --- MEMORY ---
def load_memory():
    if os.path.exists(MEMORY_FILE):
        with open(MEMORY_FILE, "r") as f:
            return json.load(f)
    return []

def save_memory(memories):
    with open(MEMORY_FILE, "w") as f:
        json.dump(memories, f, indent=2)

# --- VAULT ---
def load_vault():
    if not os.path.exists(VAULT_PATH):
        print(f"{YELLOW}  vault not found at {VAULT_PATH}. Update VAULT_PATH in the script.{R}")
        return ""

    notes = []
    for path in sorted(
        glob.glob(f"{VAULT_PATH}/**/*.md", recursive=True),
        key=os.path.getmtime,
        reverse=True
    ):
        if "Insights" in path:
            continue
        try:
            with open(path, "r", encoding="utf-8", errors="ignore") as f:
                content = f.read()[:MAX_NOTE_CHARS]
            name = os.path.basename(path)
            notes.append(f"### {name}\n{content}")
        except Exception:
            continue
        if len(notes) >= MAX_NOTES:
            break

    if not notes:
        return ""

    print(f"{DIM}  loaded {len(notes)} notes from vault{R}")
    return "\n\n---\n\n".join(notes)

# --- OLLAMA ---
def ollama_generate(prompt, system=""):
    payload = {"model": OLLAMA_MODEL, "prompt": prompt, "stream": False}
    if system:
        payload["system"] = system
    r = requests.post("http://localhost:11434/api/generate", json=payload, timeout=120)
    r.raise_for_status()
    return r.json()["response"].strip()

def ollama_chat(messages, system=""):
    # flatten history into a single prompt for compatibility
    prompt = ""
    if system:
        prompt += f"System: {system}\n\n"
    for m in messages:
        role = "User" if m["role"] == "user" else "Assistant"
        prompt += f"{role}: {m['content']}\n"
    prompt += "Assistant:"

    payload = {"model": OLLAMA_MODEL, "prompt": prompt, "stream": False}
    r = requests.post("http://localhost:11434/api/generate", json=payload, timeout=120)
    r.raise_for_status()
    return r.json()["response"].strip()

# --- EXTRACT FACTS ---
def extract_facts(user_msg):
    prompt = f"""The user said: "{user_msg}"

Extract any personal facts, preferences, or information about the user or people they know.
Output ONLY a JSON array of short fact strings. No explanation, no markdown.
If no facts found, output: []

Examples:
"dad's birthday is July 1" -> ["dad's birthday is July 1"]
"I'm allergic to shellfish" -> ["user is allergic to shellfish"]
"what time is it?" -> []"""

    try:
        raw = ollama_generate(prompt)
        match = re.search(r"\[.*?\]", raw, re.DOTALL)
        if match:
            facts = json.loads(match.group())
            return [f for f in facts if isinstance(f, str) and f.strip()]
    except Exception:
        pass
    return []

# --- MAIN ---
def main():
    print(f"\n{BOLD}{PURPLE}  memoria{R}{DIM}  personal memory + vault chat{R}")
    print(f"{DIM}  model: {OLLAMA_MODEL}  |  vault: {VAULT_PATH}{R}")
    print(f"{DIM}  commands: /memories  /forget <n>  /clear  /quit{R}\n")

    memories = load_memory()
    vault_context = load_vault()
    history = []

    if memories:
        print(f"{DIM}  {len(memories)} memories loaded{R}")
    print()

    while True:
        try:
            user_input = input(f"{BOLD}{CYAN}you > {R}").strip()
        except (EOFError, KeyboardInterrupt):
            print(f"\n{DIM}bye{R}\n")
            break

        if not user_input:
            continue

        # --- COMMANDS ---
        if user_input == "/quit":
            print(f"\n{DIM}bye{R}\n")
            break

        elif user_input == "/memories":
            if not memories:
                print(f"{DIM}  no memories yet{R}\n")
            else:
                print(f"\n{BOLD}memories:{R}")
                for i, m in enumerate(memories):
                    print(f"  {DIM}{i+1}.{R} {m}")
                print()
            continue

        elif user_input.startswith("/forget "):
            try:
                idx = int(user_input.split(" ", 1)[1]) - 1
                removed = memories.pop(idx)
                save_memory(memories)
                print(f"{DIM}  forgotten: {removed}{R}\n")
            except (ValueError, IndexError):
                print(f"{RED}  invalid index. use /memories to list them{R}\n")
            continue

        elif user_input == "/clear":
            memories = []
            save_memory(memories)
            print(f"{DIM}  all memories cleared{R}\n")
            continue

        # --- BUILD SYSTEM PROMPT ---
        system_parts = []

        if vault_context:
            system_parts.append(
                f"The user's Obsidian vault notes (most recent first):\n\n{vault_context}"
            )

        if memories:
            mem_block = "\n".join(f"- {m}" for m in memories)
            system_parts.append(f"What you know about the user:\n{mem_block}")

        system_parts.append(
            "You are a helpful personal assistant. Answer naturally and concisely. "
            "Reference vault notes or memories when relevant. "
            "Reply in the same language the user writes in."
        )

        system = "\n\n".join(system_parts)
        history.append({"role": "user", "content": user_input})

        # --- CALL OLLAMA ---
        print(f"{PURPLE}ai > {R}", end="", flush=True)
        try:
            reply = ollama_chat(history[-10:], system=system)
        except requests.exceptions.ConnectionError:
            print(f"{RED}could not reach Ollama. is it running?{R}\n")
            history.pop()
            continue
        except Exception as e:
            print(f"{RED}error: {e}{R}\n")
            history.pop()
            continue

        print(reply)
        history.append({"role": "assistant", "content": reply})

        # --- EXTRACT & SAVE FACTS ---
        new_facts = extract_facts(user_input)
        added = [f for f in new_facts if f not in memories]
        if added:
            memories.extend(added)
            save_memory(memories)
            print(f"{DIM}  remembered: {', '.join(added)}{R}")

        print()

if __name__ == "__main__":
    main()
